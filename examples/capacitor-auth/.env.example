# Point the example at the environment where native PKCE auth is deployed.
# Leave unset to use the SDK defaults (production: https://api.rool.dev).
#
# For the dev environment, set both. authUrl cannot be derived from a non
# "api."-prefixed host, so set it explicitly when apiUrl isn't api.<host>.
VITE_ROOL_API_URL=https://api.dev.rool.dev
VITE_ROOL_AUTH_URL=https://dev.rool.dev/auth
